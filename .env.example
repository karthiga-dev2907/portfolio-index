# Backend configuration
PORT=8000

# CORS settings (comma-separated origins)
# Set to your GitHub Pages URL (e.g. https://yourusername.github.io)
ALLOWED_ORIGINS=http://localhost:5173,https://yourusername.github.io

# SMTP / Email settings (e.g., SendGrid, Mailgun, Gmail)
# If left blank, backend runs in 'Mock Mode' printing messages to console
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_or_api_key
RECIPIENT_EMAIL=your_email@example.com
